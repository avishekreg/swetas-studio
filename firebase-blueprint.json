{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and preferences.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "favorites": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Item": {
      "title": "Fashion Item",
      "description": "A dress design or fabric material available for purchase.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "fabricImageUrl": { "type": "string" },
        "renderedImageUrl": { "type": "string" },
        "stock": { "type": "integer" },
        "isOneOfOne": { "type": "boolean" },
        "salePrice": { "type": "number" },
        "saleDescription": { "type": "string" },
        "styles": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "fabricImageUrl"]
    },
    "Promotion": {
      "title": "Sales Promotion",
      "description": "Information about sales, cultural offers, and discounts.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed"] },
        "discountValue": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" },
        "applicableCategories": { "type": "array", "items": { "type": "string" } },
        "bannerUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "discountType", "discountValue", "startDate", "endDate", "isActive"]
    },
    "Order": {
      "title": "Customer Order",
      "description": "Details of a purchase made by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { 
          "type": "array", 
          "items": {
            "type": "object",
            "properties": {
              "itemId": { "type": "string" },
              "quantity": { "type": "integer" },
              "type": { "type": "string", "enum": ["stitched", "material"] },
              "measurements": { "type": "object" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "razorpayOrderId": { "type": "string" },
        "trackingNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "status"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "items": {
      "schema": "Item",
      "description": "Inventory of fashion items and designs."
    },
    "orders": {
      "schema": "Order",
      "description": "Customer purchase history and order status."
    },
    "promotions": {
      "schema": "Promotion",
      "description": "Collection of active and past sales promotions and offers."
    }
  }
}
