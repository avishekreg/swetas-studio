rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isPrivileged() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["super_admin", "admin"];
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection: Users ---
    function isValidUser(data) {
      return data.email is string &&
             data.role in ['customer', 'promotions', 'customer_care', 'shipping', 'order_fulfillment', 'admin', 'super_admin'] &&
             data.uid is string &&
             data.favorites is list &&
             data.createdAt != null;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isPrivileged();
      allow list: if isPrivileged();
      allow create: if isOwner(userId) && 
                      isValidUser(incoming()) &&
                      incoming().role == "customer";
      allow update: if (isOwner(userId) && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['favorites'])) || 
                       isPrivileged();
    }

    // --- Collection: Items ---
    function isValidItem(data) {
      return data.name is string && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.fabricImageUrl is string;
    }

    match /items/{itemId} {
      allow read: if true; // Publicly browse-able
      allow create, update: if isPrivileged() && isValidItem(incoming());
      allow delete: if isPrivileged();
    }

    // --- Collection: Promotions ---
    function isValidPromotion(data) {
      return data.title is string && 
             data.discountType in ['percentage', 'fixed'] &&
             data.discountValue is number &&
             data.startDate != null &&
             data.endDate != null &&
             data.isActive is bool;
    }

    match /promotions/{promoId} {
      allow read: if true;
      allow create, update: if isPrivileged() && isValidPromotion(incoming());
      allow delete: if isPrivileged();
    }

    // --- Collection: Orders ---
    function isValidOrder(data) {
      return data.userId == request.auth.uid &&
             data.items is list && data.items.size() > 0 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status == "pending";
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isPrivileged());
      allow create: if isEmailVerified() && isValidOrder(incoming());
      allow update: if isPrivileged() && 
                       incoming().diff(existing()).affectedKeys().hasAny(['status', 'trackingNumber']);
    }
  }
}
